# =============================================================================
# Environment variables
# Copy this file to `.env.local` and fill in real values.
# Only variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# =============================================================================

# Base URL of the external .NET REST API. The frontend talks ONLY to this API.
NEXT_PUBLIC_API_BASE_URL="https://localhost:5001/api"

# API request timeout in milliseconds.
NEXT_PUBLIC_API_TIMEOUT="30000"

# Public app metadata.
NEXT_PUBLIC_APP_NAME="BMT AI Construction"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Dev-only: route auth through an in-browser mock while the .NET API is WIP.
# "true" = login works without a backend. Set "false" once the API is ready.
NEXT_PUBLIC_USE_MOCK_AUTH="false"

# Dev-only: serve feature data (projects, estimates, library…) from mocks.
# "true" = pages show sample data without a backend. Set "false" when ready.
NEXT_PUBLIC_USE_MOCK_API="false"
